# RELIX Environment Variables
# Copy this file to .env (root) and .env.local (client/) and fill in your values.

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# JWT (used by server for token signing)
JWT_SECRET=your_jwt_secret_key_here

# ─── Firebase Admin SDK (server-side) ──────────────────────────────────────────
# Option A: Path to downloaded service account JSON
GOOGLE_APPLICATION_CREDENTIALS=./config/google-service-account.json
# Option B: Project ID only (limited access, for development)
FIREBASE_PROJECT_ID=relix-6218b

# ─── Redis / Bull Queue ────────────────────────────────────────────────────────
# Fix #17a: added REDIS_URL (was missing)
REDIS_URL=redis://localhost:6379

# ─── AI Service ────────────────────────────────────────────────────────────────
# Fix #17b: added AI_SERVICE_URL (was missing)
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_PORT=8000
ANTHROPIC_API_KEY=sk-ant-your_claude_key_here

# ─── Client (Next.js) ──────────────────────────────────────────────────────────
# Fix #16: renamed VITE_* -> NEXT_PUBLIC_* (Next.js convention)
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_WS_URL=ws://localhost:5000
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Fix #17c: added NEXT_PUBLIC_FIREBASE_* vars (were missing; needed by client/src/lib/firebase.js)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy_your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Notifications (Optional) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Fix #18: Removed Supabase variables — Supabase is not used in this project.
# The database is Firebase Firestore (via Firebase Admin SDK on the server).

