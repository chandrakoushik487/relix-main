rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // Issues collection: authenticated users can read and create; writes restricted
    match /issues/{issueId} {
      // Any authenticated user (NGO, volunteer, admin) can read issues
      allow read: if request.auth != null;

      // Authenticated users can create new issues
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['issue_description', 'problem_type', 'area', 'urgency_level', 'status']);

      // Only admins or the system (server-side with admin SDK bypasses rules) can update/delete
      allow update, delete: if request.auth != null
        && request.auth.token.admin == true;
    }

    // Tasks collection: authenticated users can read and create; updates allowed for assigned users
    match /tasks/{taskId} {
      // Any authenticated user can read tasks
      allow read: if request.auth != null;

      // Authenticated users can create new tasks
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['title', 'status', 'priority']);

      // Users can update tasks if they are assigned or are admins
      allow update: if request.auth != null
        && (request.auth.token.admin == true
            || resource.data.assignedTo == request.auth.uid
            || request.resource.data.assignedTo == request.auth.uid);

      // Only admins can delete tasks
      allow delete: if request.auth != null
        && request.auth.token.admin == true;
    }

    // Jobs collection: authenticated read, no client-side writes (server handles via Admin SDK)
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // Users collection: users can only access their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

