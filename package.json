{
  "name": "relix-monorepo",
  "version": "1.0.0",
  "description": "RELIX Relief Intelligence Exchange",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build:client": "npm run build --workspace=client",
    "postbuild:client": "node -e \"require('fs').copyFileSync('index.html', 'client/out/index.html')\"",
    "build": "npm run build:client",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "deploy:main": "firebase deploy --only hosting:main --project relix-6218b --non-interactive",
    "deploy:mvp": "firebase deploy --only hosting:mvp --project relix-6218b --non-interactive",
    "deploy": "npm run build && npm run deploy:main"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "es-abstract": "^1.24.2",
    "eslint": "^8.57.0",
    "firebase-tools": "^13.10.0",
    "husky": "^9.0.11",
    "prettier": "^3.2.5",
    "update-notifier-cjs": "^5.1.7"
  },
  "dependencies": {
    "depd": "^2.0.0",
    "enhanced-resolve": "^5.20.1",
    "firebase": "^12.12.1",
    "proto-list": "^1.2.4",
    "registry-url": "^7.2.0",
    "spawn-command": "^1.0.0"
  }
}
